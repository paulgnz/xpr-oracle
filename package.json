{
  "name": "xpr-oracle",
  "version": "0.1.0",
  "description": "Minimal price-pusher daemon for XPR Network Block Producers. Fetches CEX prices, aggregates them, and submits to the on-chain delphioracle contract via cleos + keosd.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xpr-oracle": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dry-run": "tsx src/index.ts --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/aggregate.test.ts src/backoff.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
